# ============================================================
# KidsSafe AI Platform — Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Server port (default: 5000)
PORT=5000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local setup: psql -U postgres -c "CREATE DATABASE kidssafe;"
#              psql -U postgres -d kidssafe -f database/schema.sql
DATABASE_URL=postgresql://localhost:5432/kidssafe

# JWT secret key — CHANGE THIS to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=kidssafe-super-secret-jwt-key-change-this-in-production

# OpenAI API key — get one at https://platform.openai.com
# If left as the placeholder below, the app runs in demo mode with
# built-in fallback content recommendations (no API calls made).
OPENAI_API_KEY=your-openai-api-key-here

# URL of the React frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Node environment: development | production
NODE_ENV=development
